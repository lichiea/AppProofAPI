<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AppProofAPI.ViewModels"
             x:Class="AppProofAPI.Views.TestExecutionView"
             x:DataType="vm:TestExecutionViewModel"
             Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

            <!-- ЗАГОЛОВОК -->
            <Border Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Комплексное тестирование"
                               FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="{Binding ProjectName, StringFormat='Проект: {0}'}"
                               FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ПАНЕЛЬ УПРАВЛЕНИЯ -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20"
                    BorderBrush="#E2E8F0" BorderThickness="1" BoxShadow="0 1 3 0 rgba(0,0,0,0.1)">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <Grid.Styles>
                        <Style Selector="TextBlock">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                        <Style Selector="ComboBox, NumericUpDown">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#1E293B"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                    </Grid.Styles>

                    <!-- Выбор проекта -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Проект"/>
                        <ComboBox ItemsSource="{Binding AvailableProjects}"
                                  SelectedItem="{Binding SelectedProject}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="200"/>
                    </StackPanel>

                    <!-- Виртуальные пользователи -->
                    <StackPanel Grid.Column="1" Margin="0,0,20,0" MinWidth="180">
                        <TextBlock Text="Виртуальные пользователи"/>
                        <NumericUpDown Value="{Binding VuCount}" Minimum="1" Maximum="500"
                                       HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Длительность -->
                    <StackPanel Grid.Column="2" Margin="0,0,20,0" MinWidth="180">
                        <TextBlock Text="Длительность (сек)"/>
                        <NumericUpDown Value="{Binding DurationSec}" Minimum="10" Maximum="3600"
                                       HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Кнопка запуска -->
                    <Button Grid.Column="3"
                            Content="▶ Запустить тест"
                            Command="{Binding StartTestCommand}"
                            Background="#3B82F6"
                            Foreground="White"
                            Padding="32,0"
                            Height="40"
                            CornerRadius="8"
                            FontWeight="SemiBold"
                            FontSize="14"
                            VerticalAlignment="Bottom"
                            IsEnabled="{Binding !IsRunning}"
                            Margin="0,0,0,0"/>
                </Grid>
            </Border>

            <!-- ОСНОВНЫЕ МОДУЛИ (ДВЕ КОЛОНКИ) -->
            <Grid Grid.Row="2" ColumnDefinitions="*,24,*">

                <!-- ЛЕВАЯ КОЛОНКА: МНТ -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20"
                        BorderBrush="#E2E8F0" BorderThickness="1" BoxShadow="0 1 3 0 rgba(0,0,0,0.1)">
                    <StackPanel>
                        <!-- Заголовок МНТ -->
                        <Border Background="#3B82F6" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                            <DockPanel>
                                <Border Width="40" Height="40" CornerRadius="8" Background="White"
                                        DockPanel.Dock="Left" Margin="0,0,12,0">
                                    <TextBlock Text="МНТ" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" FontSize="14" Foreground="#3B82F6"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Модуль нагрузочного тестирования"
                                               FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="{Binding LoadTestStatus}"
                                               FontSize="12" Foreground="#E0F2FE" Opacity="0.9"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Прогресс -->
                        <StackPanel Margin="0,0,0,24">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Прогресс выполнения" Foreground="#64748B"/>
                                <TextBlock Text="{Binding LoadTestProgress, StringFormat={}{0:F0}%}"
                                           Foreground="#3B82F6" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <ProgressBar Value="{Binding LoadTestProgress}" Maximum="100" Height="8"
                                         Background="#E2E8F0" Foreground="#3B82F6" CornerRadius="4"/>
                        </StackPanel>

                        <!-- Метрики (сетка 2x2) -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <Border Grid.Row="0" Grid.Column="0" Background="#F8FAFC" CornerRadius="10"
                                    Padding="16" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="Всего запросов" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalRequests}"
                                               Foreground="#1E293B" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Background="#F8FAFC" CornerRadius="10"
                                    Padding="16" Margin="12,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="RPS" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding CurrentRPS, StringFormat={}{0:F1}}"
                                               Foreground="#10B981" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Background="#F8FAFC" CornerRadius="10"
                                    Padding="16" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Среднее время" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding AvgResponseTime, StringFormat={}{0} мс}"
                                               Foreground="#F59E0B" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Background="#F8FAFC" CornerRadius="10"
                                    Padding="16" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Ошибки" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding ErrorCount}"
                                               Foreground="#EF4444" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ПРАВАЯ КОЛОНКА: МТБ -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20"
                        BorderBrush="#E2E8F0" BorderThickness="1" BoxShadow="0 1 3 0 rgba(0,0,0,0.1)">
                    <StackPanel>
                        <!-- Заголовок МТБ -->
                        <Border Background="#F97316" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                            <DockPanel>
                                <Border Width="40" Height="40" CornerRadius="8" Background="White"
                                        DockPanel.Dock="Left" Margin="0,0,12,0">
                                    <TextBlock Text="МТБ" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontWeight="Bold" FontSize="14" Foreground="#F97316"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Модуль тестирования безопасности"
                                               FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="{Binding SecurityTestStatus}"
                                               FontSize="12" Foreground="#FED7AA" Opacity="0.9"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Прогресс -->
                        <StackPanel Margin="0,0,0,24">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Прогресс сканирования" Foreground="#64748B"/>
                                <TextBlock Text="{Binding SecurityTestProgress, StringFormat={}{0:F0}%}"
                                           Foreground="#F97316" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <ProgressBar Value="{Binding SecurityTestProgress}" Maximum="100" Height="8"
                                         Background="#E2E8F0" Foreground="#F97316" CornerRadius="4"/>
                        </StackPanel>

                        <!-- Метрики -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                            <Border Grid.Row="0" Grid.Column="0" Background="#F8FAFC" CornerRadius="10"
                                    Padding="16" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="Проверено эндпоинтов" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding CheckedEndpoints}"
                                               Foreground="#1E293B" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Background="#F8FAFC" CornerRadius="10"
                                    Padding="16" Margin="12,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Уязвимостей" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding FoundVulnerabilities}"
                                               Foreground="#EF4444" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Кнопка остановки -->
                        <Button Content="⏹ Остановить"
                                Command="{Binding StopCommand}"
                                Background="#EF4444"
                                Foreground="White"
                                Padding="20,10"
                                CornerRadius="8"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Stretch"
                                Margin="0,20,0,0"
                                IsVisible="{Binding IsRunning}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ВРЕМЯ ВЫПОЛНЕНИЯ -->
            <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20" Margin="0,20,0,0"
                    BorderBrush="#E2E8F0" BorderThickness="1" BoxShadow="0 1 3 0 rgba(0,0,0,0.1)">
                <DockPanel>
                    <TextBlock Text="⏱ Время выполнения:" FontSize="14" FontWeight="SemiBold"
                               Foreground="#64748B" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ElapsedTime}" FontSize="24" FontWeight="Bold"
                               Foreground="#3B82F6" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <!-- ЖУРНАЛ ВЫПОЛНЕНИЯ -->
            <Border Grid.Row="4" Background="White" CornerRadius="12" Padding="20" Margin="0,20,0,0"
                    BorderBrush="#E2E8F0" BorderThickness="1" BoxShadow="0 1 3 0 rgba(0,0,0,0.1)">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="📋 Журнал выполнения" FontSize="16" FontWeight="SemiBold"
                               Foreground="#1E293B" Margin="0,0,0,16"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="#F8FAFC" Padding="16" CornerRadius="8"
                                  MinHeight="200" MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding ExecutionLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas, 'Courier New'"
                                               FontSize="12" Foreground="#475569"
                                               TextWrapping="Wrap" Margin="0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>