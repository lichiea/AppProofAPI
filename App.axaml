<Application xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            x:Class="AppProofAPI.App"
            RequestedThemeVariant="Light">
            <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <Application.Resources>
        <!-- Цветовая палитра -->
        <Color x:Key="ColorPrimaryDark">#002147</Color>
        <Color x:Key="ColorPrimaryBlue">#002fa7</Color>
        <Color x:Key="ColorSecondaryBlue">#1034a6</Color>
        <Color x:Key="ColorAccentBlue">#0047ab</Color>
        <Color x:Key="ColorLightBlue">#4169e1</Color>
        <Color x:Key="ColorSky">#6495ed</Color>
        <Color x:Key="BgMain">#f8fafc</Color>
        <Color x:Key="BgCard">#ffffff</Color>
        <Color x:Key="BgSidebar">#002147</Color>
        <Color x:Key="TextPrimary">#0f172a</Color>
        <Color x:Key="TextSecondary">#475569</Color>
        <Color x:Key="TextMuted">#64748b</Color>
        <Color x:Key="TextOnDark">#ffffff</Color>
        <Color x:Key="BorderColor">#e2e8f0</Color>

        <SolidColorBrush x:Key="BgMainBrush" Color="{StaticResource BgMain}" />
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}" />
        <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
        <SolidColorBrush x:Key="TextOnDarkBrush" Color="{StaticResource TextOnDark}" />

        <CornerRadius x:Key="RadiusMd">6</CornerRadius>
        <CornerRadius x:Key="RadiusLg">8</CornerRadius>
        <!-- BoxShadow удалён из ресурсов – задаётся непосредственно в стилях -->
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://Avalonia.Themes.Fluent/FluentTheme.xaml" />

        <!-- Стили текста -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>

        <!-- Стиль для карточек -->
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
            <Setter Property="BoxShadow" Value="0 1 3 0 rgba(0,0,0,0.05)" />
        </Style>

        <!-- Стиль для заголовка карточки -->
        <Style Selector="Border.CardHeader">
            <Setter Property="Background" Value="#fafafa" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0 0 0 1" />
            <Setter Property="Padding" Value="16 12" />
        </Style>
    </Application.Styles>
</Application>