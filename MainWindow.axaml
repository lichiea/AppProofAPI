<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AppProofAPI.ViewModels"
        xmlns:views="clr-namespace:AppProofAPI.Views"
        x:Class="AppProofAPI.MainWindow"
        Icon="/Assets/logo.ico"
        Title=""
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BgMainBrush}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:ImportViewModel}">
            <views:ImportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoadTestViewModel}">
            <views:LoadTestView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SecurityTestViewModel}">
            <views:SecurityTestView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestExecutionViewModel}">
            <views:TestExecutionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectDetailsViewModel}">
            <views:ProjectDetailsView />
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>
        <!-- Боковая панель -->
        <Border DockPanel.Dock="Left"
                Width="260"
                Background="{StaticResource BgSidebarBrush}">
            <DockPanel LastChildFill="True">
                <!-- Заголовок -->
                <Border DockPanel.Dock="Top" Padding="20 16" BorderThickness="0 0 0 1" BorderBrush="#1a334d">
                    <DockPanel>
                        <Border Width="32" Height="32" CornerRadius="6" Background="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="{StaticResource ColorLightBlue}" />
                                    <GradientStop Offset="1" Color="{StaticResource ColorSky}" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="P" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    FontWeight="Bold" FontSize="16" Foreground="White" />
                        </Border>
                        <TextBlock Text="ProofAPI" FontSize="16" FontWeight="SemiBold" Foreground="White"
                                VerticalAlignment="Center" Margin="10 0 0 0" />
                    </DockPanel>
                </Border>

                <!-- Меню навигации (ListBox) -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0 12 0 0">
                        <ListBox ItemsSource="{Binding MenuItems}"
                                SelectedItem="{Binding SelectedMenuItem}"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16 8" Background="Transparent">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#1a334d" />
                                            </Style>
                                        </Border.Styles>
                                        <DockPanel>
                                            <Path DockPanel.Dock="Left" Margin="0 0 12 0"
                                                Data="{Binding Icon}" Stroke="White" StrokeThickness="1.5"
                                                Width="16" Height="16" />
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <!-- РАЗДЕЛИТЕЛЬ И ЗАГОЛОВОК СЕКЦИИ "ПРОЕКТЫ" -->
                        <Border Margin="16 24 16 8" BorderThickness="0 0 0 1" BorderBrush="#1a334d" Padding="0 0 0 8">
                            <TextBlock Text="ПРОЕКТЫ" Foreground="#8899AA" FontSize="11" FontWeight="Bold" />
                        </Border>
                        <!-- СПИСОК ПРОЕКТОВ ИЗ БАЗЫ ДАННЫХ -->
                        <ListBox ItemsSource="{Binding Projects}"
                            SelectedItem="{Binding SelectedProject}"
                            Background="Transparent"
                            BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16 8" Background="Transparent" Cursor="Hand">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#1a334d" />
                                            </Style>
                                        </Border.Styles>
                                        <DockPanel>
                                            <!-- КНОПКА УДАЛЕНИЯ (Корзина) -->
                                            <Button DockPanel.Dock="Right"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4"
                                                VerticalAlignment="Center"
                                                ToolTip.Tip="Удалить проект"
                                                Command="{Binding $parent[Window].DataContext.DeleteProjectCommand}"
                                                CommandParameter="{Binding}">
                                                <Path Data="M6 19a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                    Fill="#ff4d4f" Width="16" Height="16" StrokeThickness="0"/>
                                            </Button>
                                            <!-- Информация о проекте -->
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                    Foreground="White"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding OpenAPIFilePath}"
                                                    Foreground="#8899AA"
                                                    FontSize="11"
                                                    TextTrimming="CharacterEllipsis"
                                                    Margin="0 4 0 0"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Основная область -->
        <ContentControl DockPanel.Dock="Right"
                        Content="{Binding CurrentPage}"
                        Background="{StaticResource BgMainBrush}" />
    </DockPanel>
</Window>
