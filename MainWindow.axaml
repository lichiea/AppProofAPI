<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AppProofAPI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="AppProofAPI.MainWindow"
        Title="API Client - Postman Like"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <Grid RowDefinitions="Auto,*">
        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlForegroundChromeBlackMediumBrush}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Send" Command="{Binding SendCommand}" Width="80" Margin="8,0,0,0" Background="#FF6C37" Foreground="White" />
                <TextBox DockPanel.Dock="Left" Text="{Binding RequestUrl}" PlaceholderText="Enter URL" Margin="8,0" VerticalAlignment="Center">
                    <TextBox.Styles>
                        <Style Selector="TextBox">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </TextBox.Styles>
                </TextBox>
                <ComboBox DockPanel.Dock="Left" SelectedItem="{Binding SelectedHttpMethod}" ItemsSource="{Binding HttpMethods}" Width="100" Margin="8,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1" ColumnDefinitions="250,5,*">
            <!-- Левая панель -->
            <Border Grid.Column="0" Background="{DynamicResource SystemAltHighColor}">
                <DockPanel>
                    <TextBlock Text="Collections" DockPanel.Dock="Top" FontWeight="Bold" Margin="10,10,10,5" />
                    <TreeView ItemsSource="{Binding Collections}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" />
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" Background="{DynamicResource SystemControlForegroundChromeBlackMediumBrush}" />

            <!-- Правая область -->
            <ScrollViewer Grid.Column="2">
                <StackPanel Margin="10">
                    <!-- Вкладки -->
                    <TabControl Margin="0,10">
                        <TabItem Header="Params">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding QueryParams}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,*,Auto" Margin="0,2">
                                                <TextBox Text="{Binding Key}" PlaceholderText="Key" Grid.Column="0" Margin="2" />
                                                <TextBox Text="{Binding Value}" PlaceholderText="Value" Grid.Column="1" Margin="2" />
                                                <Button Content="✕" Command="{Binding RemoveCommand}" Width="30" Grid.Column="2" Margin="2" Background="Transparent" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Add param" Command="{Binding AddQueryParamCommand}" Margin="0,5" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Headers">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding Headers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,*,Auto" Margin="0,2">
                                                <TextBox Text="{Binding Key}" PlaceholderText="Header name" Grid.Column="0" Margin="2" />
                                                <TextBox Text="{Binding Value}" PlaceholderText="Header value" Grid.Column="1" Margin="2" />
                                                <Button Content="✕" Command="{Binding RemoveCommand}" Width="30" Grid.Column="2" Margin="2" Background="Transparent" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="Add header" Command="{Binding AddHeaderCommand}" Margin="0,5" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Body">
                            <TextBox Text="{Binding RequestBody}" AcceptsReturn="True" Height="150" />
                        </TabItem>
                    </TabControl>

                    <!-- Область ответа -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundChromeBlackMediumBrush}" BorderThickness="1" Margin="0,10">
                        <StackPanel>
                            <Grid Background="{DynamicResource SystemAltHighColor}" Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Status:" Grid.Column="0" FontWeight="Bold" />
                                <TextBlock Text="{Binding ResponseStatus}" Grid.Column="1" Margin="5,0,15,0" />
                                <TextBlock Text="Time:" Grid.Column="2" FontWeight="Bold" />
                                <TextBlock Text="{Binding ResponseTime}" Grid.Column="3" Margin="5,0,0,0" />
                            </Grid>
                            <TabControl>
                                <TabItem Header="Body">
                                    <TextBox Text="{Binding ResponseBody}" AcceptsReturn="True" Height="200" IsReadOnly="True" />
                                </TabItem>
                                <TabItem Header="Headers">
                                    <TextBox Text="{Binding ResponseHeaders}" AcceptsReturn="True" Height="200" IsReadOnly="True" />
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>